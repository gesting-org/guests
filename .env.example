# Supabase — requerido para que la app funcione
# Obtené estos valores en: https://supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# MercadoPago — pagos con tarjeta
# Public key (empieza con APP_USR- en producción, TEST- en test)
# Obtené tu key en: https://www.mercadopago.com.ar/developers → Tu aplicación → Credenciales
VITE_MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# WhatsApp (CallMeBot) — notificaciones al host
# Número en formato internacional sin + (ej: 5491165358015)
VITE_HOST_WHATSAPP=
# API key recibida por WhatsApp al activar CallMeBot
VITE_CALLMEBOT_API_KEY=

# Copiá este archivo como .env y completá los valores reales.
# NUNCA commitees el .env con credenciales reales.
